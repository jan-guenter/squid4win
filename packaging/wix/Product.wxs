<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <?define ProductName = "Squid4Win" ?>
  <?define Manufacturer = "Squid4Win Contributors" ?>
  <?define UpgradeCode = "E118A5AC-15CA-4A6C-AFA2-C5B2D73E52B6" ?>

  <Package
      Name="$(var.ProductName)"
      Manufacturer="$(var.Manufacturer)"
      Version="$(var.ProductVersion)"
      UpgradeCode="$(var.UpgradeCode)"
      InstallerVersion="500"
      Scope="perMachine"
      Compressed="yes"
      Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />
    <Launch Condition="VersionNT64" Message="This installation package is only supported on 64-bit Windows." />
    <Launch Condition='NOT (INSTALLFOLDER &gt;&lt; " ")'
            Message="Install root cannot contain spaces because Squid's Windows service startup does not preserve quoted config paths. Choose a path without spaces, such as C:\Squid4Win." />

    <Property Id="ROOTDRIVE" Value="C:\" />
    <Property Id="INSTALLLEVEL" Value="100" />
    <UIRef Id="WixUI_ErrorProgressText" />
    <ui:WixUI Id="WixUI_FeatureTree" />

    <StandardDirectory Id="TARGETDIR">
      <Directory Id="INSTALLFOLDER" Name="Squid4Win" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationShortcutFolder" Name="Squid4Win" />
    </StandardDirectory>

    <Property Id="SQUID4WIN_SERVICE_NAME" Value="$(var.SquidServiceName)" />

    <ComponentGroup Id="TrayIntegration" Directory="INSTALLFOLDER">
      <Component Id="TrayShortcutComponent" Guid="*">
        <Shortcut Id="TrayShortcut"
                  Directory="ApplicationShortcutFolder"
                  Name="Squid4Win"
                  Description="Open the Squid4Win tray application."
                  Target="[INSTALLFOLDER]Squid4Win.Tray.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveApplicationShortcuts"
                      Directory="ApplicationShortcutFolder"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Squid4Win"
                       Name="TrayShortcutInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="TrayAutostartIntegration" Directory="INSTALLFOLDER">
      <Component Id="TrayAutostartComponent" Guid="*">
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
                       Name="Squid4Win.Tray"
                       Type="string"
                       Value="[INSTALLFOLDER]Squid4Win.Tray.exe"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="MainFeature"
             Title="Squid4Win"
             Level="1"
             Display="expand"
             ConfigurableDirectory="INSTALLFOLDER"
             AllowAbsent="no">
      <ComponentGroupRef Id="CorePayload" />
      <Feature Id="TrayFeature"
               Title="System tray application"
               Description="Install the optional Squid4Win tray UI."
               Level="$(var.TrayFeatureLevel)"
               AllowAbsent="yes">
        <ComponentGroupRef Id="TrayPayload" />
        <ComponentGroupRef Id="TrayIntegration" />
        <Feature Id="TrayAutostartFeature"
                 Title="Start tray application at logon"
                 Description="Start the tray application automatically for all users at Windows logon."
                 Level="$(var.TrayAutostartFeatureLevel)"
                 AllowAbsent="yes">
          <ComponentGroupRef Id="TrayAutostartIntegration" />
        </Feature>
      </Feature>
    </Feature>

    <!--
      Append "." to INSTALLFOLDER when passing it as a quoted argument. MSI
      directory properties end with a trailing backslash, which would otherwise
      escape the closing quote in the raw QuietExec command line.
    -->
    <SetProperty Id="InstallSquidService"
                 Sequence="execute"
                 After="CostFinalize"
                 Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]installer\svc.ps1&quot; Install &quot;[INSTALLFOLDER].&quot; &quot;[SQUID4WIN_SERVICE_NAME]&quot;"
                 Condition="NOT Installed" />

    <CustomAction Id="InstallSquidService"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  DllEntry="WixQuietExec"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)" />

    <SetProperty Id="RemoveSquidService"
                 Sequence="execute"
                 After="CostFinalize"
                 Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]installer\svc.ps1&quot; Uninstall &quot;[INSTALLFOLDER].&quot; &quot;[SQUID4WIN_SERVICE_NAME]&quot;"
                 Condition="REMOVE=&quot;ALL&quot;" />

    <CustomAction Id="RemoveSquidService"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"
                  DllEntry="WixQuietExec"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)" />

    <InstallExecuteSequence>
      <Custom Action="InstallSquidService"
              After="InstallFiles"
              Condition="NOT Installed" />
      <Custom Action="RemoveSquidService"
              Before="RemoveFiles"
              Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>
