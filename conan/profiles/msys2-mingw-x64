# Conan-managed host profile for the native Windows Squid build.
# Toolchain executables and the MSYS2 bash environment come from Conan
# tool requirements, not from hardcoded local paths.

[settings]
os=Windows
arch=x86_64
compiler=gcc
compiler.version=15
compiler.cppstd=gnu17
compiler.libcxx=libstdc++11
compiler.exception=seh
compiler.threads=posix
build_type=Release
