{
  "platform": "windows-x64",
  "toolchain": "native-msys2",
  "msys2Env": "mingw64",
  "msys2RootHints": [
    "C:\\msys64",
    "C:\\tools\\msys64",
    "D:\\a\\_temp\\msys64"
  ],
  "requiredMsys2Packages": [
    "autoconf",
    "automake",
    "libtool",
    "make",
    "mingw-w64-x86_64-make",
    "mingw-w64-x86_64-pkgconf",
    "mingw-w64-x86_64-binutils",
    "mingw-w64-x86_64-gcc",
    "mingw-w64-x86_64-libgnurx",
    "mingw-w64-x86_64-libxml2",
    "mingw-w64-x86_64-openssl",
    "mingw-w64-x86_64-pcre2",
    "mingw-w64-x86_64-zlib"
  ],
  "hostTriplet": "x86_64-w64-mingw32",
  "compilerCppStd": "gnu17",
  "compilerLibCxx": "libstdc++11",
  "compilerException": "seh",
  "compilerThreads": "posix",
  "installer": "wix4",
  "trayApp": "wpf",
  "conanHome": ".\\.conan2",
  "conanProfileName": "msys2-mingw-x64",
  "conanToolRequirements": [
    "mingw-builds/15.1.0"
  ],
  "conanRequirements": [
    "openssl/3.6.1",
    "pcre2/10.44",
    "libxml2/2.15.2",
    "zlib/1.3.1"
  ],
  "stageRoot": "build\\install\\release",
  "serviceName": "Squid4Win",
  "configureCache": {
    "ac_cv_sizeof_void_p": "8",
    "ac_cv_c_int8_t": "yes",
    "ac_cv_c_uint8_t": "yes",
    "ac_cv_c_int16_t": "yes",
    "ac_cv_c_uint16_t": "yes",
    "ac_cv_c_int32_t": "yes",
    "ac_cv_c_uint32_t": "yes",
    "ac_cv_c_int64_t": "yes",
    "ac_cv_c_uint64_t": "yes",
    "ac_cv_type_pid_t": "yes",
    "ac_cv_type_size_t": "yes",
    "ac_cv_type_ssize_t": "yes",
    "ac_cv_type_off_t": "yes",
    "ac_cv_sizeof_int64_t": "8",
    "ac_cv_sizeof_off_t": "4",
    "ac_cv_sizeof_size_t": "8"
  },
  "configureArgs": [
    "--disable-strict-error-checking",
    "--disable-dependency-tracking",
    "--without-netfilter-conntrack",
    "--enable-auth-basic=DB,NCSA,POP3,RADIUS,SMB,SSPI,fake",
    "--enable-auth-digest=file",
    "--enable-auth-negotiate=SSPI",
    "--enable-external-acl-helpers=LM_group,SQL_session,delayer,wbinfo_group",
    "--with-openssl",
    "--enable-win32-service",
    "--enable-default-hostsfile"
  ]
}
